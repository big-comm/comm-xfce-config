[Trigger]
Type = Path
Operation = Install
Operation = Upgrade
Target = usr/share/xsessions/xfce.desktop
Target = usr/bin/startxfce-community

[Action]
Description = Replace startxfce4 with startxfce-community in xfce.desktop
When = PostTransaction
Exec = /usr/share/libalpm/scripts/startxfce-community
