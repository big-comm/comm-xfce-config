#!/bin/bash

# Defining the default visual style to be used in applications that use Qt
[[ -z $QT_STYLE_OVERRIDE ]] && export QT_STYLE_OVERRIDE="kvantum"
[[ -z $QT_QPA_PLATFORMTHEME ]] && export QT_QPA_PLATFORMTHEME="xdg-desktop-portal"
[[ -z $QT_WAYLAND_DECORATION ]] && export QT_WAYLAND_DECORATION="adwaita"

# Apps in electron use wayland
[[ -z $ELECTRON_OZONE_PLATFORM_HINT ]] && export ELECTRON_OZONE_PLATFORM_HINT="auto"

# If using mesa amber force cairo renderer
if compgen -G /var/lib/pacman/local/mesa-amber-* || systemd-detect-virt -q; then
    [[ -z $GSK_RENDERER ]] && export GSK_RENDERER="cairo"
else
    [[ -z $GSK_RENDERER ]] && export GSK_RENDERER="ngl"
fi

# Configure first boot settings (theme)
# xfconfd may already be running (activated by sync-gnome-theme-to-qt.service
# via WantedBy=default.target). Kill it after modifying XMLs to force reload.
# Also write dconf directly to avoid race with dconf-sync-monitor dump.
#-------------------------------------------------------------------------------
themeFile="/etc/big-default-config/theme"
if [[ -e "$themeFile" && ! -e "$HOME/.big_desktop_theme" ]]; then
    settings_file="$HOME/.config/dconf/settings.xfce"
    theme="$(<"$themeFile")"

    # Apply light theme if selected (skel defaults to dark)
    if [[ "$theme" == "light" && -e "$settings_file" ]]; then
        logger "Applying light theme on first boot"

        # Update xfconf XML files
        xsettings_file="$HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xsettings.xml"
        if [[ -e "$xsettings_file" ]]; then
            sed -i 's|value="adw-gtk3-dark"|value="adw-gtk3"|g' "$xsettings_file"
            sed -i 's|value="bigicons-papient-dark"|value="bigicons-papient-light"|g' "$xsettings_file"
            logger "Updated xfconf xsettings.xml for light theme"
        fi

        xfwm4_file="$HOME/.config/xfce4/xfconf/xfce-perchannel-xml/xfwm4.xml"
        if [[ -e "$xfwm4_file" ]]; then
            sed -i 's|value="adw-gtk3-dark"|value="adw-gtk3"|g' "$xfwm4_file"
            logger "Updated xfconf xfwm4.xml for light theme"
        fi

        # Kill xfconfd to discard stale cache from pre-sed XML reads
        pkill -u "$USER" xfconfd 2>/dev/null
        logger "Killed xfconfd to force XML reload"

        # Update dconf settings file (for dconf load later)
        sed -i "s|color-scheme='prefer-dark'|color-scheme='default'|g" "$settings_file"
        sed -i "s|gtk-theme='adw-gtk3-dark'|gtk-theme='adw-gtk3'|g" "$settings_file"
        sed -i "s|icon-theme='bigicons-papient-dark'|icon-theme='bigicons-papient-light'|g" "$settings_file"

        # Write dconf directly → survives dconf-sync-monitor initial dump race
        dconf write /org/gnome/desktop/interface/gtk-theme "'adw-gtk3'"
        dconf write /org/gnome/desktop/interface/icon-theme "'bigicons-papient-light'"
        dconf write /org/gnome/desktop/interface/color-scheme "'default'"
        logger "Wrote light theme values directly to dconf"
    fi

    # JamesDSP configuration
    jamesdsp_conf="$HOME/.config/jamesdsp/application.conf"
    if [[ -e "$jamesdsp_conf" ]]; then
        if [[ -e /etc/big-default-config/jamesdsp ]]; then
            sed -i "s|AutoStartEnabled=false|AutoStartEnabled=true|g" "$jamesdsp_conf"
            systemctl --user restart jamesdsp-autostart.service 2>/dev/null
            logger "JamesDSP autostart enabled on first boot"
        else
            sed -i "s|AutoStartEnabled=true|AutoStartEnabled=false|g" "$jamesdsp_conf"
            systemctl --user stop jamesdsp-autostart.service 2>/dev/null
            logger "JamesDSP autostart disabled on first boot"
        fi
    fi

    touch "$HOME/.big_desktop_theme"
fi

# Check system theme to apply if the QT theme is clade or dark
if [ -f "/usr/share/sync-kde-and-gtk-places/sync-gnome-theme-to-qt.sh" ]; then
    # Tenta executar 3 vezes com intervalo de 1 segundo
    for i in {1..3}; do
        if /usr/share/sync-kde-and-gtk-places/sync-gnome-theme-to-qt.sh; then
            logger "sync-gnome-theme-to-qt.sh executed successfully"
            break
        else
            logger "Failed to execute sync-gnome-theme-to-qt.sh, attempt $i"
            sleep 0.5
        fi
    done
else
    logger "sync-gnome-theme-to-qt.sh not found"
fi

# Force language
if [ "$LANGUAGE" = "" ]; then
    [[ -z $LANGUAGE ]] && export LANGUAGE=$LANG
fi

# Checks if the shell has already been changed
if [ ! -f "$HOME/.biglinux-shell-changed" ]; then
    biglinux-change-default-shell bash-power
    touch "$HOME/.biglinux-shell-changed"
fi

#OBS Studio game capture with vulkan
if [ -e "/usr/bin/obs-vkcapture" ]; then
    [[ -z $OBS_USE_EGL ]] && export OBS_USE_EGL=1
    [[ -z $OBS_VKCAPTURE ]] && export OBS_VKCAPTURE=1
    [[ -z $VK_INSTANCE_LAYERS ]] && export VK_INSTANCE_LAYERS="VK_LAYER_OBS_vkcapture_64:VK_LAYER_VALVE_steam_overlay_64" #Fix MangoHUD overlay
fi

#Keyboard LED
if [ -e "$HOME/.config/ledkeyboard" ]; then
    change-keyboard-led on
fi

# Get the current cursor theme
currentTheme=$(dconf read /org/gnome/desktop/interface/cursor-theme)

# Check if the current theme is 'Breeze_Light'
if [ "$currentTheme" == "'Breeze_Light'" ]; then
    # Change the cursor theme to 'Bibata-Modern-Classic'
    dconf write /org/gnome/desktop/interface/cursor-theme "'Bibata-Modern-Classic'"
fi

# Path to the control file
controlFile="$HOME/.config/Thunar/uca.xml"

# Check if the control file exists
if [ ! -f "$controlFile" ]; then
    # Execute the command if the control file does not exist
    /usr/local/bin/thunar-actions-translated.sh
fi

if [[ -e "$HOME/.first-boot" ]]; then
    rm -f "$HOME/.first-boot"
    logger "First boot configuration completed"
fi


#-------------------------------------------------------------------------------
# # --- START Configuration dconf and mimeapps
#-------------------------------------------------------------------------------
dconf_dir="$HOME/.config/dconf"
mimeapps_dir="$HOME/.config"
log_file="/tmp/dconf-switch-xfce.log"

# Function to log messages
log_message() {
    echo "[$(date '+%Y-%m-%d %H:%M:%S')] [XFCE] $1" | tee -a "$log_file"
}

# Function to load mimeapps configuration
load_mimeapps_config() {
    log_message "Loading XFCE mimeapps configuration"

    if [ -f "$mimeapps_dir/xfce.mimeapps.list" ]; then
        log_message "Found existing XFCE mimeapps, loading..."
        cp "$mimeapps_dir/xfce.mimeapps.list" "$mimeapps_dir/mimeapps.list"
    else
        log_message "No existing XFCE mimeapps found, creating empty file"
        touch "$mimeapps_dir/mimeapps.list"
    fi
}

# Function to load dconf configuration
load_dconf_config() {
    mkdir -p "$dconf_dir"

    log_message "Loading XFCE dconf configuration"
    log_message "XDG_CURRENT_DESKTOP: $XDG_CURRENT_DESKTOP"

    # Load configuration for XFCE
    local settings_file="$dconf_dir/settings.xfce"
    local backup_file="$dconf_dir/settings.xfce.bak"

    # Restore from backup if settings file is empty or missing (forced shutdown protection)
    if [[ -f "$settings_file" && ! -s "$settings_file" && -s "$backup_file" ]]; then
        log_message "WARNING: settings.xfce is empty, restoring from backup"
        cp -f "$backup_file" "$settings_file"
        log_message "Backup restored successfully"
    fi

    if [[ -s "$settings_file" ]]; then
        log_message "Found existing XFCE settings, loading..."
        log_message "Resetting dconf database"
        dconf reset -f /

        log_message "Loading settings from: $settings_file"
        if dconf load / < "$settings_file"; then
            log_message "XFCE settings loaded successfully"
        else
            log_message "ERROR: Failed to load XFCE settings"
            # Try backup if main file failed to load
            if [[ -s "$backup_file" ]]; then
                log_message "Attempting to load from backup..."
                if dconf load / < "$backup_file"; then
                    log_message "Backup settings loaded successfully"
                    cp -f "$backup_file" "$settings_file"
                fi
            fi
        fi
    else
        log_message "No existing XFCE settings found - will create on first save"
    fi
}

# Function to start systemd sync services
start_sync_services() {
    log_message "Starting sync services..."

    # Start dconf sync service
    log_message "Starting dconf-sync-xfce.service"
    if systemctl --user enable dconf-sync-xfce.service 2>/dev/null; then
        log_message "dconf-sync service enabled"
    fi
    if systemctl --user restart dconf-sync-xfce.service 2>/dev/null; then
        log_message "dconf-sync service started successfully"
    else
        log_message "WARNING: Failed to start dconf-sync service"
    fi

    # Start mimeapps sync service
    log_message "Starting mimeapps-sync-xfce.service"
    if systemctl --user enable mimeapps-sync-xfce.service 2>/dev/null; then
        log_message "mimeapps-sync service enabled"
    fi
    if systemctl --user restart mimeapps-sync-xfce.service 2>/dev/null; then
        log_message "mimeapps-sync service started successfully"
    else
        log_message "WARNING: Failed to start mimeapps-sync service"
    fi
}

# Main execution
log_message "=========================================="
log_message "Starting XFCE session configuration"
log_message "=========================================="

# Load configurations
load_mimeapps_config
load_dconf_config

# Start monitoring services
start_sync_services

log_message "XFCE session configuration completed"
# --- END Configuration dconf and mimeapps ---


#-------------------------------------------------------------------------------
# ### Execute in LiveCD
#-------------------------------------------------------------------------------
if [ -e /usr/bin/startbiglive ]; then
    # Set XFCE environment variables
    export XDG_MENU_PREFIX=xfce-
    export DESKTOP_SESSION=xfce
    export XDG_SESSION_DESKTOP=xfce
    export GDMSESSION=xfce
    export XDG_CURRENT_DESKTOP=XFCE

    # Enables basic, unencrypted password storage in Chromium-based browsers
    sudo sed -i '/--password-store=basic/!s/\(exec \/usr\/lib\/brave-browser\/brave "$@" $USER_FLAGS\)$/\1 --password-store=basic/' /usr/bin/brave

    # Updates user directories
    LANG=$LANG xdg-user-dirs-update --force

    # Get the correct path for the Desktop, regardless of language
    homeBigDesk=$(xdg-user-dir DESKTOP)
    cfile='calamares-biglinux.desktop'

    if [ ! -d "$homeBigDesk" ]; then
        mkdir -p "$homeBigDesk"
    fi

    cp -f /usr/share/applications/$cfile "$homeBigDesk/"
    chmod +x "$homeBigDesk/$cfile"

    # Generate the SHA256sum of the file on each boot
    checksum=$(sha256sum "$homeBigDesk/$cfile" | awk '{print $1}')

    # Set metadata using gio
    gio set "$homeBigDesk/$cfile" metadata::xfce-exe-checksum "$checksum"
    gio set "$homeBigDesk/$cfile" metadata::trusted true

    # Disables the prompt about updating directories
    echo "enabled=false" > "$HOME/.config/user-dirs.conf"

    # Remove switch user
    xfconf-query -c xfce4-session -np '/shutdown/ShowSwitchUser' -t 'bool' -s 'false'

    # Disable screen lock
    xfconf-query -c xfce4-screensaver -p /saver/enabled -n -t bool -s false

    # Remove the lock screen button
    xfconf-query -c xfce4-panel -p $(xfconf-query -c xfce4-panel -l | grep show-command-lockscreen) -s false
fi

# Kill light-locker if present → conflicts with xfce4-screensaver, causes unwanted screen blanking
pkill -x light-locker 2>/dev/null

# Execute startxfce4, passing through any arguments
exec /usr/bin/startxfce4 "$@"
